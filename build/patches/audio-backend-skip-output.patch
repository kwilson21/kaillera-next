+   /* 2026-04-25: deterministic-mode early exit.
+    * Skip the resampler (native FP) and audio_batch_cb (Asyncify yield)
+    * to eliminate cross-engine non-determinism in the audio output path.
+    * Audio HLE has already finished writing samples to N64 RDRAM by this
+    * point; we just don't translate them to host audio output. */
+   if (kn_skip_audio_output) {
+      return;
+   }
+
+#ifdef __EMSCRIPTEN__
+   if (kn_deterministic_mode) {
+      kn_capture_audio_direct(raw_data, frames);
+      return;
+   }
+#endif
+
