@@ -48,6 +48,38 @@ extern retro_audio_sample_batch_t audio_batch_cb;
 
 static unsigned MAX_AUDIO_FRAMES = 2048;
 
+/* 2026-04-25: deterministic-mode audio output bypass.
+ *
+ * The default aiLenChanged path runs a sinc resampler (native float) +
+ * calls audio_batch_cb (libretro audio output, which is an Emscripten
+ * JS-import → Asyncify yield point). Both have cross-engine timing/FP
+ * behavior that varies between V8 and JSC, leaking determinism through
+ * the AI/SP subsystem state hashes (confirmed via SUBSYS-DIFF on
+ * V8/JSC pairs while V8/V8 pairs stayed clean).
+ *
+ * When kn_skip_audio_output != 0, aiLenChanged returns immediately
+ * (after the byte-swap, since the swap mutates the caller's buffer in
+ * place — matching legacy semantics). RSP audio HLE still runs and
+ * the AI controller's internal state evolves; only the final
+ * resampler + JS output callback is skipped.
+ *
+ * In deterministic mode, audible netplay audio is captured directly from
+ * the AI buffer below, before the libretro/RetroArch/OpenAL output path.
+ * That path can be suspended or bypassed by the browser, so depending on
+ * it for capture leaves JS with zero PCM samples. */
+#ifdef __EMSCRIPTEN__
+#include <emscripten.h>
+#endif
+int kn_skip_audio_output = 0;
+#ifdef __EMSCRIPTEN__
+EMSCRIPTEN_KEEPALIVE
+#endif
+void kn_set_skip_audio_output(int skip) { kn_skip_audio_output = skip ? 1 : 0; }
+#ifdef __EMSCRIPTEN__
+EMSCRIPTEN_KEEPALIVE
+#endif
+int kn_get_skip_audio_output(void) { return kn_skip_audio_output; }
+
 #define VI_INTR_TIME 500000
 #define OUTPUT_RATE 44100
 
@@ -57,6 +89,45 @@ static unsigned CountsPerSecond;
 static unsigned BytesPerSecond;
 static unsigned CountsPerByte;
 
+#ifdef __EMSCRIPTEN__
+extern int kn_deterministic_mode;
+extern int16_t kn_audio_buffer[];
+extern int kn_audio_sample_count;
+extern int kn_audio_rate;
+
+static void kn_capture_audio_direct(const int16_t *raw_data, size_t frames)
+{
+   size_t i;
+   size_t out_frames;
+   int space;
+
+   if (!kn_deterministic_mode || !raw_data || frames == 0 || GameFreq <= 0)
+      return;
+
+   kn_audio_rate = OUTPUT_RATE;
+   space = 48000 - kn_audio_sample_count;
+   if (space <= 0)
+      return;
+
+   out_frames = (size_t)(((uint64_t)frames * OUTPUT_RATE + ((unsigned)GameFreq / 2)) / (unsigned)GameFreq);
+   if (out_frames == 0)
+      out_frames = 1;
+   if (out_frames > (size_t)space)
+      out_frames = (size_t)space;
+
+   for (i = 0; i < out_frames; i++)
+   {
+      size_t src = (size_t)(((uint64_t)i * (unsigned)GameFreq) / OUTPUT_RATE);
+      if (src >= frames)
+         src = frames - 1;
+      kn_audio_buffer[(kn_audio_sample_count + (int)i) * 2] = raw_data[src * 2];
+      kn_audio_buffer[(kn_audio_sample_count + (int)i) * 2 + 1] = raw_data[src * 2 + 1];
+   }
+
+   kn_audio_sample_count += (int)out_frames;
+}
+#endif
+
 #ifdef __APPLE__
 /* Apple AudioConverter - resamples int16 to 44100 Hz.
