 void ColorBufferToRDRAM::_copy(u32 _startAddress, u32 _endAddress, bool _sync)
 {
+	/* kaillera-next: every byte GLideN64 is about to write into [_startAddress,
+	 * _endAddress) comes from a GL texture readback whose bytes differ across
+	 * GPU drivers, GLES implementations, and even iOS minor versions. Flag the
+	 * range as tainted before we touch it. */
+	if (_endAddress > _startAddress)
+		kn_taint_rdram(_startAddress, _endAddress - _startAddress);
+
 	const u32 stride = m_pCurFrameBuffer->m_width << m_pCurFrameBuffer->m_size >> 1;
 	const u32 max_height = std::min((u32)VI_GetMaxBufferHeight(m_pCurFrameBuffer->m_width), cutHeight(_startAddress, m_pCurFrameBuffer->m_height, stride));
 
