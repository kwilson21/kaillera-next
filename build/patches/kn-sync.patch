+/* ================================================================
+ * kaillera-next: C-level state sync for lockstep netplay resync.
+ *
+ * Bypasses retro_serialize/retro_unserialize to avoid WASM memory
+ * growth and HEAPU8 buffer detachment that causes resync cascades
+ * on mobile. Three exports:
+ *   kn_sync_hash  - FNV-1a of SSB64 VS mode RDRAM regions
+ *   kn_sync_read  - serialize gameplay-critical state to buffer
+ *   kn_sync_write - restore gameplay-critical state from buffer
+ * ================================================================ */
+
+#include "../device/r4300/r4300_core.h"
+
+EMSCRIPTEN_KEEPALIVE uint32_t kn_sync_hash(void)
+{
+    /* FNV-1a hash of SSB64 VS mode RDRAM regions.
+     * Regions verified by Playwright MCP visual scan.
+     * Computed entirely in C - no HEAPU8, no JS boundary. */
+    const uint8_t *rdram = (const uint8_t *)g_dev.rdram.dram;
+    uint32_t hash = 2166136261u; /* FNV offset basis */
+    int i, r;
+
+    static const uint32_t regions[] = {
+        0xA4000,  0xBA000,  0xBF000,  0xC4000,
+        0x262000, 0x266000, 0x26A000, 0x290000,
+        0x2F6000, 0x32B000, 0x330000, 0x335000
+    };
+    static const int SAMPLE = 256;
+
+    for (r = 0; r < 12; r++)
+    {
+        const uint8_t *p = rdram + regions[r];
+        for (i = 0; i < SAMPLE; i++)
+        {
+            hash ^= p[i];
+            hash *= 16777619u; /* FNV prime */
+        }
+    }
+    return hash;
+}
+
+/* kn_sync_read: Serialize gameplay-critical state into buf.
+ * Returns bytes written. Caller must provide buf of at least 8MB + 16KB.
+ *
+ * Layout: [header 16B] [RDRAM 8MB] [GPR 256B] [CP0 regs] [CP0_extras 8B]
+ *         [CP1 256B] [CP1_ctl 8B] [llbit+hi+lo+PC 24B]
+ *         [VI 8B] [TLB 32*entry] [EventQueue 1024B] [SP_MEM 8KB] [PIF 64B]
+ */
+EMSCRIPTEN_KEEPALIVE uint32_t kn_sync_read(uint8_t *buf, uint32_t max_size)
+{
+    struct device *dev = &g_dev;
+    uint8_t *p = buf;
+    uint32_t *header;
+    int i;
+    char queue[1024];
+
+    if (!buf || max_size < RDRAM_MAX_SIZE + 16384)
+        return 0;
+
+    /* Header: magic + version + total size (filled at end) */
+    header = (uint32_t *)p;
+    header[0] = 0x4B4E5331; /* "KNS1" */
+    header[1] = 1;           /* version */
+    header[2] = 0;           /* total size (filled below) */
+    header[3] = 0;           /* reserved */
+    p += 16;
+
+    /* RDRAM (8MB) */
+    memcpy(p, dev->rdram.dram, RDRAM_MAX_SIZE);
+    p += RDRAM_MAX_SIZE;
+
+    /* R4300 GPR (32 x int64 = 256B) */
+    memcpy(p, r4300_regs(&dev->r4300), 32 * sizeof(int64_t));
+    p += 32 * sizeof(int64_t);
+
+    /* CP0 regs */
+    memcpy(p, r4300_cp0_regs(&dev->r4300.cp0), CP0_REGS_COUNT * sizeof(uint32_t));
+    p += CP0_REGS_COUNT * sizeof(uint32_t);
+
+    /* CP0 extras: next_interrupt + Count */
+    {
+        unsigned int next_int = *r4300_cp0_next_interrupt(&dev->r4300.cp0);
+        uint32_t count = dev->r4300.cp0.regs[CP0_COUNT_REG];
+        memcpy(p, &next_int, 4); p += 4;
+        memcpy(p, &count, 4); p += 4;
+    }
+
+    /* CP1 regs (32 x cp1_reg = 256B) */
+    memcpy(p, r4300_cp1_regs(&dev->r4300.cp1), 32 * sizeof(cp1_reg));
+    p += 32 * sizeof(cp1_reg);
+
+    /* CP1 control: fcr0 + fcr31 */
+    {
+        uint32_t fcr0 = *r4300_cp1_fcr0(&dev->r4300.cp1);
+        uint32_t fcr31 = *r4300_cp1_fcr31(&dev->r4300.cp1);
+        memcpy(p, &fcr0, 4); p += 4;
+        memcpy(p, &fcr31, 4); p += 4;
+    }
+
+    /* llbit + hi + lo + PC */
+    {
+        unsigned int llbit = *r4300_llbit(&dev->r4300);
+        int64_t hi = *r4300_mult_hi(&dev->r4300);
+        int64_t lo = *r4300_mult_lo(&dev->r4300);
+        uint32_t pc = *r4300_pc(&dev->r4300);
+        memcpy(p, &llbit, 4); p += 4;
+        memcpy(p, &hi, 8); p += 8;
+        memcpy(p, &lo, 8); p += 8;
+        memcpy(p, &pc, 4); p += 4;
+    }
+
+    /* VI timing: field + delay */
+    {
+        unsigned int vi_field = dev->vi.field;
+        unsigned int vi_delay = dev->vi.delay;
+        memcpy(p, &vi_field, 4); p += 4;
+        memcpy(p, &vi_delay, 4); p += 4;
+    }
+
+    /* TLB entries (32 entries) - raw struct copy */
+    for (i = 0; i < 32; i++)
+    {
+        memcpy(p, &dev->r4300.cp0.tlb.entries[i],
+               sizeof(dev->r4300.cp0.tlb.entries[i]));
+        p += sizeof(dev->r4300.cp0.tlb.entries[i]);
+    }
+
+    /* Event queue (1024B) */
+    save_eventqueue_infos(&dev->r4300.cp0, queue);
+    memcpy(p, queue, sizeof(queue));
+    p += sizeof(queue);
+
+    /* SP memory (8KB) */
+    memcpy(p, dev->sp.mem, SP_MEM_SIZE);
+    p += SP_MEM_SIZE;
+
+    /* PIF RAM (64B) */
+    memcpy(p, dev->pif.ram, PIF_RAM_SIZE);
+    p += PIF_RAM_SIZE;
+
+    /* Fill header total size */
+    header[2] = (uint32_t)(p - buf);
+
+    return (uint32_t)(p - buf);
+}
+
+/* kn_sync_write: Restore gameplay-critical state from buf.
+ * Returns 0 on success, -1 on error.
+ * Modeled on the PJ64 restore path in savestates.c:1281-1328
+ * and the m64p restore post-processing. */
+EMSCRIPTEN_KEEPALIVE int kn_sync_write(const uint8_t *buf, uint32_t size)
+{
+    struct device *dev = &g_dev;
+    const uint8_t *p = buf;
+    const uint32_t *header;
+    int i;
+    char queue[1024];
+    uint32_t pc_val;
+
+    if (!buf || size < 16)
+        return -1;
+
+    /* Validate header */
+    header = (const uint32_t *)p;
+    if (header[0] != 0x4B4E5331 || header[1] != 1)
+        return -1;
+    p += 16;
+
+    /* RDRAM (8MB) */
+    memcpy(dev->rdram.dram, p, RDRAM_MAX_SIZE);
+    p += RDRAM_MAX_SIZE;
+
+    /* R4300 GPR */
+    memcpy(r4300_regs(&dev->r4300), p, 32 * sizeof(int64_t));
+    p += 32 * sizeof(int64_t);
+
+    /* CP0 regs */
+    memcpy(r4300_cp0_regs(&dev->r4300.cp0), p,
+           CP0_REGS_COUNT * sizeof(uint32_t));
+    p += CP0_REGS_COUNT * sizeof(uint32_t);
+
+    /* CP0 extras */
+    {
+        unsigned int next_int;
+        uint32_t count;
+        memcpy(&next_int, p, 4); p += 4;
+        memcpy(&count, p, 4); p += 4;
+        *r4300_cp0_next_interrupt(&dev->r4300.cp0) = next_int;
+        dev->r4300.cp0.regs[CP0_COUNT_REG] = count;
+    }
+
+    /* CP1 regs */
+    memcpy(r4300_cp1_regs(&dev->r4300.cp1), p, 32 * sizeof(cp1_reg));
+    p += 32 * sizeof(cp1_reg);
+
+    /* CP1 control */
+    {
+        uint32_t fcr0, fcr31;
+        memcpy(&fcr0, p, 4); p += 4;
+        memcpy(&fcr31, p, 4); p += 4;
+        *r4300_cp1_fcr0(&dev->r4300.cp1) = fcr0;
+        *r4300_cp1_fcr31(&dev->r4300.cp1) = fcr31;
+    }
+
+    /* llbit + hi + lo + PC */
+    {
+        unsigned int llbit;
+        int64_t hi, lo;
+        memcpy(&llbit, p, 4); p += 4;
+        memcpy(&hi, p, 8); p += 8;
+        memcpy(&lo, p, 8); p += 8;
+        memcpy(&pc_val, p, 4); p += 4;
+        *r4300_llbit(&dev->r4300) = llbit;
+        *r4300_mult_hi(&dev->r4300) = hi;
+        *r4300_mult_lo(&dev->r4300) = lo;
+        /* PC set via savestates_load_set_pc below */
+    }
+
+    /* VI timing */
+    {
+        unsigned int vi_field, vi_delay;
+        memcpy(&vi_field, p, 4); p += 4;
+        memcpy(&vi_delay, p, 4); p += 4;
+        dev->vi.field = vi_field;
+        dev->vi.delay = vi_delay;
+    }
+
+    /* TLB: restore entries then rebuild LUT tables (PJ64-style) */
+    memset(dev->r4300.cp0.tlb.LUT_r, 0, 0x400000);
+    memset(dev->r4300.cp0.tlb.LUT_w, 0, 0x400000);
+
+    for (i = 0; i < 32; i++)
+    {
+        memcpy(&dev->r4300.cp0.tlb.entries[i], p,
+               sizeof(dev->r4300.cp0.tlb.entries[i]));
+        p += sizeof(dev->r4300.cp0.tlb.entries[i]);
+
+        /* Rebuild LUT mapping for this entry */
+        tlb_map(&dev->r4300.cp0.tlb, i);
+    }
+
+    /* Event queue */
+    memcpy(queue, p, sizeof(queue));
+    p += sizeof(queue);
+    load_eventqueue_infos(&dev->r4300.cp0, queue);
+
+    /* SP memory */
+    memcpy(dev->sp.mem, p, SP_MEM_SIZE);
+    p += SP_MEM_SIZE;
+
+    /* PIF RAM + channel format rebuild */
+    memcpy(dev->pif.ram, p, PIF_RAM_SIZE);
+    p += PIF_RAM_SIZE;
+    setup_channels_format(&dev->pif);
+
+    /* Post-restore calls (modeled on savestates_load_m64p) */
+    {
+        uint32_t *cp0 = r4300_cp0_regs(&dev->r4300.cp0);
+
+        /* FPR pointer setup - must happen after CP0 STATUS and CP1 regs set */
+        set_fpr_pointers(&dev->r4300.cp1, cp0[CP0_STATUS_REG]);
+        update_x86_rounding_mode(&dev->r4300.cp1);
+
+        /* PC restoration - updates instruction pipeline, invalidates cache */
+        savestates_load_set_pc(&dev->r4300, pc_val);
+    }
+
+    return 0;
+}
 #endif

 m64p_media_loader g_media_loader;
