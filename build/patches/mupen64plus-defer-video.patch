diff --git a/libretro/libretro.c b/libretro/libretro.c
index ee8ca7c..6a17752 100644
--- a/libretro/libretro.c
+++ b/libretro/libretro.c
@@ -112,6 +112,41 @@ retro_video_refresh_t video_cb = NULL;
 #include <emscripten.h>
 int kn_headless = 0;
 EMSCRIPTEN_KEEPALIVE void kn_set_headless(int enable) { kn_headless = enable; }
+
+int kn_defer_video = 0;
+static int kn_video_pending = 0;
+static const void *kn_video_data = NULL;
+static unsigned kn_video_width = 0;
+static unsigned kn_video_height = 0;
+static size_t kn_video_pitch = 0;
+
+EMSCRIPTEN_KEEPALIVE void kn_set_defer_video(int enable) {
+    kn_defer_video = enable ? 1 : 0;
+    if (!kn_defer_video)
+        kn_video_pending = 0;
+}
+
+static void kn_video_emit(const void *data, unsigned width, unsigned height, size_t pitch) {
+    if (!kn_defer_video) {
+        video_cb(data, width, height, pitch);
+        return;
+    }
+
+    kn_video_data = data;
+    kn_video_width = width;
+    kn_video_height = height;
+    kn_video_pitch = pitch;
+    kn_video_pending = 1;
+}
+
+EMSCRIPTEN_KEEPALIVE int kn_video_drain(void) {
+    if (!kn_video_pending)
+        return 0;
+
+    kn_video_pending = 0;
+    video_cb(kn_video_data, kn_video_width, kn_video_height, kn_video_pitch);
+    return 1;
+}
 
 /* kaillera-next: Write full controller input for a slot.
  * Called by kn_rollback.c during replay to set inputs before retro_run().
@@ -2128,19 +2157,19 @@ void retro_run (void)
     {
        if(current_rdp_type == RDP_PLUGIN_GLIDEN64)
        {
-          video_cb(RETRO_HW_FRAME_BUFFER_VALID, retro_screen_width, retro_screen_height, 0);
+          kn_video_emit(RETRO_HW_FRAME_BUFFER_VALID, retro_screen_width, retro_screen_height, 0);
        }
 #ifdef HAVE_THR_AL
        else if(current_rdp_type == RDP_PLUGIN_ANGRYLION)
        {
-          video_cb(prescale, retro_screen_width, retro_screen_height, screen_pitch);
+          kn_video_emit(prescale, retro_screen_width, retro_screen_height, screen_pitch);
        }
 #endif // HAVE_THR_AL
 #ifdef HAVE_PARALLEL_RDP
        else if (current_rdp_type == RDP_PLUGIN_PARALLEL)
        {
            parallel_profile_video_refresh_begin();
-           video_cb(parallel_frame_is_valid() ? RETRO_HW_FRAME_BUFFER_VALID : NULL,
+           kn_video_emit(parallel_frame_is_valid() ? RETRO_HW_FRAME_BUFFER_VALID : NULL,
                    parallel_frame_width(), parallel_frame_height(), 0);
            parallel_profile_video_refresh_end();
        }
@@ -2150,7 +2179,7 @@ void retro_run (void)
     else if(EnableFrameDuping)
     {
         // screen_pitch will be 0 for GLN
-        video_cb(NULL, retro_screen_width, retro_screen_height, screen_pitch);
+        kn_video_emit(NULL, retro_screen_width, retro_screen_height, screen_pitch);
     }
 #ifdef __EMSCRIPTEN__
     }
