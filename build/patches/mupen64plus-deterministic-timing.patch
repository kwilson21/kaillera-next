diff --git a/mupen64plus-core/src/main/main.c b/mupen64plus-core/src/main/main.c
index 3ef61a2..f97572b 100644
--- a/mupen64plus-core/src/main/main.c
+++ b/mupen64plus-core/src/main/main.c
@@ -129,6 +129,20 @@ uint32_t g_start_address = UINT32_C(0xa4000040);
 
 struct device g_dev;
 
+#ifdef __EMSCRIPTEN__
+#include <emscripten.h>
+#include "../device/r4300/cp0.h"
+/* kaillera-next: Export the N64 CPU cycle count as a deterministic time source.
+ * CP0_COUNT_REG (index 9) increments with each CPU cycle. Both emulators
+ * execute the same instructions → same cycle count → deterministic timing.
+ * N64 CPU runs at 93.75 MHz, so cycles / 93750.0 = milliseconds. */
+EMSCRIPTEN_KEEPALIVE double kn_get_cycle_time_ms(void)
+{
+    uint32_t cycles = g_dev.r4300.cp0.regs[CP0_COUNT_REG];
+    return (double)cycles / 93750.0;
+}
+#endif
+
 m64p_media_loader g_media_loader;
 
 int g_gs_vi_counter = 0;
diff --git a/mupen64plus-core/src/main/profile.c b/mupen64plus-core/src/main/profile.c
index fe710c3..78ec9e6 100644
--- a/mupen64plus-core/src/main/profile.c
+++ b/mupen64plus-core/src/main/profile.c
@@ -53,6 +53,13 @@ static long long int last_start[NUM_TIMED_SECTIONS];
 
   static long long int get_time(void)
   {
+#ifdef __EMSCRIPTEN__
+     /* kaillera-next: deterministic timing for lockstep netplay */
+     extern int kn_deterministic_mode;
+     extern double kn_frame_time_ms;
+     if (kn_deterministic_mode)
+        return (long long int)(kn_frame_time_ms * 1000000.0);
+#endif
      struct timespec ts;
      clock_gettime(CLOCK_MONOTONIC, &ts);
      return (long long int)ts.tv_sec * 1000000000 + ts.tv_nsec;
