 retro_video_refresh_t video_cb = NULL;
+
+/* kaillera-next: Headless tick mode — skip all GL state management and video
+ * callbacks in retro_run(). CPU emulation (co_switch) still runs normally.
+ * Used to benchmark raw emulation speed for GGPO-style rollback feasibility. */
+#ifdef __EMSCRIPTEN__
+#include <emscripten.h>
+int kn_headless = 0;
+EMSCRIPTEN_KEEPALIVE void kn_set_headless(int enable) { kn_headless = enable; }
+
+/* kaillera-next: Write full controller input for a slot.
+ * Called by kn_rollback.c during replay to set inputs before retro_run().
+ * Mirrors the JS applyInputToWasm() logic in shared.js. */
+extern void simulate_input(int user, int key, int down);
+
+/* Scale N64 analog (+-83) to RetroArch range (+-32767).
+ * MUST match JS applyInputToWasm: Math.trunc(v * (32767.0 / 83.0))
+ * Uses float division + truncation, NOT integer division. */
+static int kn_clamp_analog(int v) {
+    double scaled = (double)v * (32767.0 / 83.0);
+    int result = (int)scaled; /* truncates toward zero like Math.trunc */
+    if (result > 32767) result = 32767;
+    if (result < -32767) result = -32767;
+    return result;
+}
+
+void kn_write_controller(int slot, int buttons, int lx, int ly, int cx, int cy) {
+    int i;
+    /* Digital buttons (0-15): each bit maps to a simulate_input key */
+    for (i = 0; i < 16; i++) {
+        simulate_input(slot, i, (buttons >> i) & 1);
+    }
+    /* L-stick: scale N64 range (+-83) to RetroArch range (+-32767) */
+    simulate_input(slot, 16, lx > 0 ? kn_clamp_analog(lx) : 0);   /* X+ right */
+    simulate_input(slot, 17, lx < 0 ? kn_clamp_analog(-lx) : 0);  /* X- left */
+    simulate_input(slot, 18, ly > 0 ? kn_clamp_analog(ly) : 0);    /* Y+ down */
+    simulate_input(slot, 19, ly < 0 ? kn_clamp_analog(-ly) : 0);   /* Y- up */
+    /* C-stick: axis values OR digital button bitmask (bits 20-23) */
+    {
+        int cmax = kn_clamp_analog(83); /* 32767 — matches JS clamp(N64_MAX) */
+        simulate_input(slot, 20, cx > 0 ? kn_clamp_analog(cx) : ((buttons >> 20) & 1) ? cmax : 0);
+        simulate_input(slot, 21, cx < 0 ? kn_clamp_analog(-cx) : ((buttons >> 21) & 1) ? cmax : 0);
+        simulate_input(slot, 22, cy > 0 ? kn_clamp_analog(cy) : ((buttons >> 22) & 1) ? cmax : 0);
+        simulate_input(slot, 23, cy < 0 ? kn_clamp_analog(-cy) : ((buttons >> 23) & 1) ? cmax : 0);
+    }
+}
+#endif
