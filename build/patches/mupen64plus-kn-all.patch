+/* kn_frame_hash: perceptual hash of the N64 VI framebuffer.
+ * Reads VI_ORIGIN_REG to find the framebuffer in RDRAM, stride-samples it
+ * down to 16x16 pixels, and FNV-1a hashes the result. Zero GPU readback —
+ * pure RDRAM access. Returns 0 if VI is not configured (no framebuffer).
+ * Used for visual desync detection: if both players' frame hashes match
+ * across a sliding window, the game is visually in sync regardless of
+ * what RDRAM anchor hashing says. */
+EMSCRIPTEN_KEEPALIVE uint32_t kn_frame_hash(void)
+{
+    const uint8_t *rdram = (const uint8_t *)g_dev.rdram.dram;
+    uint32_t status = g_dev.vi.regs[VI_STATUS_REG];
+    uint32_t origin = g_dev.vi.regs[VI_ORIGIN_REG] & 0x00FFFFFF; /* 24-bit RDRAM addr */
+    uint32_t width  = g_dev.vi.regs[VI_WIDTH_REG];
+    uint32_t bpp = status & 3; /* 2 = 16-bit RGBA5551, 3 = 32-bit RGBA8888 */
+    uint32_t pixel_bytes, stride, fb_size, hash, x, y;
+    const uint32_t THUMB = 16; /* 16x16 downsampled thumbnail */
+    /* Height: derive from VI_V_START (active video lines).
+     * Upper 10 bits = start line, lower 10 bits = end line.
+     * Difference / 2 = active height (fields are interlaced). */
+    uint32_t v_start = g_dev.vi.regs[VI_V_START_REG];
+    uint32_t height = ((v_start & 0x3FF) - ((v_start >> 16) & 0x3FF)) / 2;
+    if (bpp < 2 || width == 0 || height == 0 || origin >= RDRAM_MAX_SIZE) return 0;
+    pixel_bytes = (bpp == 3) ? 4 : 2;
+    stride = width * pixel_bytes;
+    fb_size = stride * height;
+    if (origin + fb_size > RDRAM_MAX_SIZE) return 0;
+    hash = 2166136261u;
+    for (y = 0; y < THUMB; y++) {
+        uint32_t src_y = (y * height) / THUMB;
+        for (x = 0; x < THUMB; x++) {
+            uint32_t src_x = (x * width) / THUMB;
+            uint32_t off = origin + src_y * stride + src_x * pixel_bytes;
+            /* Hash the first 2 bytes of each sampled pixel (covers RGB in both formats) */
+            hash ^= rdram[off]; hash *= 16777619u;
+            hash ^= rdram[off + 1]; hash *= 16777619u;
+        }
+    }
+    return hash;
+}
