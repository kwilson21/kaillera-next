diff --git a/mupen64plus-rsp-hle/src/hle.c b/mupen64plus-rsp-hle/src/hle.c
--- a/mupen64plus-rsp-hle/src/hle.c
+++ b/mupen64plus-rsp-hle/src/hle.c
@@ -179,6 +179,74 @@ void rsp_break(struct hle_t* hle, unsigned int setbits)
     }
 }

+#ifdef __EMSCRIPTEN__
+#include <emscripten.h>
+#include <string.h>
+#include <stdlib.h>
+#include <stddef.h>
+/* kaillera-next: RSP audio determinism for netplay.
+ * mode 0: normal (RSP writes to DRAM)
+ * mode 1: skip entirely (silent, fastest, DRAM untouched)
+ * mode 2: process for audio capture, then restore DRAM + HLE state (audio works, fully deterministic) */
+int kn_skip_rsp_audio = 0;
+EMSCRIPTEN_KEEPALIVE void kn_set_skip_rsp_audio(int skip) { kn_skip_rsp_audio = skip; }
+static uint8_t *kn_rsp_audio_snapshot = NULL;
+static uint8_t *kn_hle_state_snapshot = NULL;
+#define KN_RSP_AUDIO_DRAM_START 0x80000u
+#define KN_RSP_AUDIO_DRAM_SIZE  0x60000u
+/* Persistent audio state in hle_t: alist_buffer through mp3_buffer.
+ * Saved/restored alongside DRAM so non-deterministic HLE processing
+ * doesn't leak divergent state into subsequent audio tasks. */
+#define KN_HLE_STATE_OFFSET offsetof(struct hle_t, alist_buffer)
+#define KN_HLE_STATE_SIZE   (offsetof(struct hle_t, cached_ucodes) - offsetof(struct hle_t, alist_buffer))
+#endif
+
 static void send_alist_to_audio_plugin(struct hle_t* hle)
 {
+#ifdef __EMSCRIPTEN__
+    if (kn_skip_rsp_audio == 1) {
+        rsp_break(hle, SP_STATUS_TASKDONE);
+        return;
+    }
+    if (kn_skip_rsp_audio >= 2) {
+        if (!kn_rsp_audio_snapshot) {
+            kn_rsp_audio_snapshot = (uint8_t *)malloc(KN_RSP_AUDIO_DRAM_SIZE);
+        }
+        if (!kn_hle_state_snapshot) {
+            kn_hle_state_snapshot = (uint8_t *)malloc(KN_HLE_STATE_SIZE);
+        }
+        if (kn_rsp_audio_snapshot && kn_hle_state_snapshot && hle->dram) {
+            /* Save DRAM audio region */
+            memcpy(kn_rsp_audio_snapshot, hle->dram + KN_RSP_AUDIO_DRAM_START, KN_RSP_AUDIO_DRAM_SIZE);
+            /* Save hle_t persistent audio state (ADPCM tables, envelopes, alist_buffer) */
+            memcpy(kn_hle_state_snapshot, ((uint8_t *)hle) + KN_HLE_STATE_OFFSET, KN_HLE_STATE_SIZE);
+            /* Process audio (produces audio output for capture + modifies DRAM and hle_t) */
+            HleProcessAlistList(hle->user_defined);
+            /* Restore DRAM — deterministic for game logic */
+            memcpy(hle->dram + KN_RSP_AUDIO_DRAM_START, kn_rsp_audio_snapshot, KN_RSP_AUDIO_DRAM_SIZE);
+            /* Restore hle_t state — prevents non-deterministic audio state from
+             * persisting across task calls and cascading into future divergence */
+            memcpy(((uint8_t *)hle) + KN_HLE_STATE_OFFSET, kn_hle_state_snapshot, KN_HLE_STATE_SIZE);
+            rsp_break(hle, SP_STATUS_TASKDONE);
+        } else {
+            rsp_break(hle, SP_STATUS_TASKDONE);
+        }
+        return;
+    }
+#endif
     HleProcessAlistList(hle->user_defined);
     rsp_break(hle, SP_STATUS_TASKDONE);
 }
