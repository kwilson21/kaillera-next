diff --git a/mupen64plus-rsp-hle/src/memory.h b/mupen64plus-rsp-hle/src/memory.h
index 9c85104..b48cd79 100644
--- a/mupen64plus-rsp-hle/src/memory.h
+++ b/mupen64plus-rsp-hle/src/memory.h
@@ -166,18 +166,29 @@ static inline void dram_load_u32(struct hle_t* hle, uint32_t* dst, uint32_t addr
     load_u32(dst, hle->dram, address & 0xffffff, count);
 }
 
+/* kaillera-next: taint hook. Every RSP HLE write to main RDRAM flags the
+ * written 64 KB block(s) as non-deterministic so kn_game_state_hash can
+ * skip them. RSP HLE emulates audio/video microcode on the host CPU — the
+ * host's FPU, JIT, and memory layout produce per-device differences in the
+ * bytes DMAed back to RDRAM. Those bytes never influence game logic, but
+ * they poison any naive full-RAM hash. */
+extern void kn_taint_rdram(uint32_t addr, uint32_t size);
+
 static inline void dram_store_u8(struct hle_t* hle, const uint8_t* src, uint32_t address, size_t count)
 {
+    kn_taint_rdram(address & 0xffffff, (uint32_t)count);
     store_u8(hle->dram, address & 0xffffff, src, count);
 }
 
 static inline void dram_store_u16(struct hle_t* hle, const uint16_t* src, uint32_t address, size_t count)
 {
+    kn_taint_rdram(address & 0xffffff, (uint32_t)(count * sizeof(uint16_t)));
     store_u16(hle->dram, address & 0xffffff, src, count);
 }
 
 static inline void dram_store_u32(struct hle_t* hle, const uint32_t* src, uint32_t address, size_t count)
 {
+    kn_taint_rdram(address & 0xffffff, (uint32_t)(count * sizeof(uint32_t)));
     store_u32(hle->dram, address & 0xffffff, src, count);
 }
 
