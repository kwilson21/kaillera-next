+/* ---- kaillera-next: SoftFloat integration for cross-platform determinism ---- */
+#ifdef __EMSCRIPTEN__
+#include "softfloat.h"
+
+/* Type-punning helpers: convert between C float/double and SoftFloat types.
+ * Uses memcpy to avoid strict-aliasing violations. */
+static inline float32_t kn_to_f32(float f) {
+    float32_t r; uint32_t bits; memcpy(&bits, &f, 4); r.v = bits; return r;
+}
+static inline float kn_from_f32(float32_t f) {
+    float r; memcpy(&r, &f.v, 4); return r;
+}
+static inline float64_t kn_to_f64(double d) {
+    float64_t r; uint64_t bits; memcpy(&bits, &d, 8); r.v = bits; return r;
+}
+static inline double kn_from_f64(float64_t f) {
+    double r; memcpy(&r, &f.v, 8); return r;
+}
+/* Runtime SoftFloat bypass: when kn_native_fpu = 1, use native C FPU ops
+ * instead of SoftFloat. Declared in main.c (kn-all patch). */
+extern int kn_native_fpu;
+#endif /* __EMSCRIPTEN__ */
 
