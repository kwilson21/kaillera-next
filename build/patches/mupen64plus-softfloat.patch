+++ b/Makefile
@@ -569,5 +569,12 @@ else ifeq ($(platform), emscripten) 
    COREFLAGS += -DOS_LINUX
    STATIC_LINKING = 1
+
+   # kaillera-next: Berkeley SoftFloat 3e include paths for FPU determinism.
+   # SoftFloat source lives outside the git-cloned repos at /build/softfloat/.
+   # The .c files are compiled separately by build.sh and merged into the .bc.
+   SOFTFLOAT_DIR ?= $(ROOT_DIR)/../../softfloat
+   INCFLAGS += -I$(SOFTFLOAT_DIR)/include -I$(SOFTFLOAT_DIR)/8086-SSE -I$(SOFTFLOAT_DIR)
+
 # Windows
 else
    TARGET := $(TARGET_NAME)_libretro.dll
