diff --git a/mupen64plus-core/src/main/main.c b/mupen64plus-core/src/main/main.c
--- a/mupen64plus-core/src/main/main.c
+++ b/mupen64plus-core/src/main/main.c
@@ -139,6 +139,33 @@ EMSCRIPTEN_KEEPALIVE double kn_get_cycle_time_ms(void)
     uint32_t cycles = g_dev.r4300.cp0.regs[CP0_COUNT_REG];
     return (double)cycles / 93750.0;
 }
+
+/* kaillera-next: Reset CP0_COUNT to zero and realign the interrupt queue.
+ * Called at lockstep start on all players after state sync to eliminate
+ * the cycle count offset between host (more boot frames) and guests.
+ * Without this, CP0_COUNT bit-31 wrap triggers SPECIAL_INT at different
+ * frames on host vs guests, causing desync ~45s into gameplay. */
+EMSCRIPTEN_KEEPALIVE void kn_reset_cycle_count(void)
+{
+    extern void translate_event_queue(struct cp0*, unsigned int);
+    translate_event_queue(&g_dev.r4300.cp0, UINT32_C(0));
+}
+
+/* kaillera-next: Canonicalize NaN in all 32 FPU registers.
+ * Called once per frame from JS before stepOneFrame(). */
+#include "../device/r4300/cp1.h"
+#include <string.h>
+#include <math.h>
+EMSCRIPTEN_KEEPALIVE void kn_canon_fpu_regs(void)
+{
+    static const uint32_t canon_nan_f = 0x7FC00000;
+    cp1_reg* regs = r4300_cp1_regs(&g_dev.r4300.cp1);
+    int i;
+    for (i = 0; i < 32; i++) {
+        if (isnan(regs[i].float32[0]))
+            memcpy(&regs[i].float32[0], &canon_nan_f, sizeof(float));
+        if (isnan(regs[i].float32[1]))
+            memcpy(&regs[i].float32[1], &canon_nan_f, sizeof(float));
+    }
+}
 #endif
