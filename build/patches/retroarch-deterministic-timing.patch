diff --git a/frontend/drivers/platform_emulatorjs.c b/frontend/drivers/platform_emulatorjs.c
index c9ceed1..9ef5d8b 100644
--- a/frontend/drivers/platform_emulatorjs.c
+++ b/frontend/drivers/platform_emulatorjs.c
@@ -15,6 +15,7 @@
  * If not, see <http://www.gnu.org/licenses/>.
  */
 
+#include <stdint.h>
 #include <emscripten/emscripten.h>
 #include <emscripten/html5.h>
 #include <emscripten/threading.h>
@@ -115,6 +116,46 @@ typedef struct
 
 static emscripten_platform_data_t *emscripten_platform_data = NULL;
 
+/* kaillera-next: Deterministic timing for lockstep netplay.
+ * When kn_deterministic_mode is non-zero, all timing functions return
+ * values derived from the N64 CPU cycle counter (CP0 Count register)
+ * instead of real wall-clock time. This is deterministic because both
+ * emulators execute the same instructions and have the same cycle count.
+ *
+ * kn_get_cycle_time_ms() reads the CP0 Count register and converts it
+ * to milliseconds. This is what Project64k/Kaillera effectively did —
+ * timing was derived from CPU cycles, not wall clock. */
+int kn_deterministic_mode = 0;
+double kn_frame_time_ms = 0.0;
+
+/* kaillera-next: Audio capture buffer for deterministic audio bypass.
+ * When kn_deterministic_mode is on, al_write() copies PCM samples here
+ * instead of sending to OpenAL. JS reads after each frame step. */
+#define KN_AUDIO_BUF_SAMPLES 48000
+int16_t kn_audio_buffer[KN_AUDIO_BUF_SAMPLES * 2]; /* stereo interleaved int16 */
+int kn_audio_sample_count = 0;
+int kn_audio_rate = 0;  /* set by al_init() */
+
+EMSCRIPTEN_KEEPALIVE void* kn_get_audio_ptr(void)    { return kn_audio_buffer; }
+EMSCRIPTEN_KEEPALIVE int   kn_get_audio_samples(void) { return kn_audio_sample_count; }
+EMSCRIPTEN_KEEPALIVE void  kn_reset_audio(void)       { kn_audio_sample_count = 0; }
+EMSCRIPTEN_KEEPALIVE int   kn_get_audio_rate(void)    { return kn_audio_rate; }
+
+EMSCRIPTEN_KEEPALIVE void kn_set_frame_time(double time_ms)
+{
+   kn_frame_time_ms = time_ms;
+}
+
+EMSCRIPTEN_KEEPALIVE void kn_set_deterministic(int enable)
+{
+   kn_deterministic_mode = enable;
+}
+
+EMSCRIPTEN_KEEPALIVE int kn_get_deterministic(void)
+{
+   return kn_deterministic_mode;
+}
+
 /* defined here since implementation is frontend dependent */
 
 void retro_sleep(unsigned msec)
@@ -328,6 +369,15 @@ bool platform_emscripten_is_window_hidden(void)
 
 bool platform_emscripten_should_drop_iter(void)
 {
+   /* kaillera-next: In lockstep/rollback netplay the JS side drives frame
+    * stepping and must never silently drop a tick — if iOS reports the page
+    * as hidden or a transient GL context loss occurs on one device, the
+    * other device keeps running and the two diverge by one+ frames with
+    * no visible cause. Force-return false so core_run always executes when
+    * called. The JS engine is responsible for not calling stepOneFrame
+    * when it shouldn't. */
+   if (kn_deterministic_mode)
+      return false;
    return (emscripten_platform_data->gl_context_lost || (emscripten_platform_data->window_hidden && emscripten_platform_data->raf_interval));
 }
 
