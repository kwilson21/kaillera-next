# kaillera-next server configuration
# Uncomment and modify values as needed

# CORS origin — set to your domain in production, "*" for development
# ALLOWED_ORIGIN=https://yourdomain.com

# Server port (default: 27888)
# PORT=27888

# Room limits
# MAX_ROOMS=100
# MAX_SPECTATORS=20

# Admin page — REQUIRED, admin endpoints are blocked when not set
# ADMIN_KEY=your-secret-key-here

# Redis password (must match docker-compose redis --requirepass)
# REDIS_PASSWORD=changeme

# Trusted proxy IPs for X-Forwarded-For (comma-separated, "*" = trust all)
# Set to your reverse proxy IP in production
# TRUSTED_PROXY_IPS=*

# Log retention in days — unpinned logs older than this are auto-cleaned
# LOG_RETENTION_DAYS=14

# Sync log storage directory
# SYNC_LOG_DIR=logs/sync

# Custom STUN/TURN servers (JSON array)
# Default: Cloudflare STUN only (no relay fallback)
# For TURN relay (recommended), sign up at metered.ca or run your own coturn
# ICE_SERVERS=[{"urls":"stun:stun.relay.metered.ca:80"},{"urls":"turn:global.relay.metered.ca:80","username":"YOUR_USERNAME","credential":"YOUR_CREDENTIAL"},{"urls":"turn:global.relay.metered.ca:443","username":"YOUR_USERNAME","credential":"YOUR_CREDENTIAL"},{"urls":"turns:global.relay.metered.ca:443?transport=tcp","username":"YOUR_USERNAME","credential":"YOUR_CREDENTIAL"}]

# Enable verbose sync logging to logs/live.log
# DEBUG_MODE=1
